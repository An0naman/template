{
  "name": "Weather Check - Smart Short Cycles",
  "version": "1.0.16",
  "description": "Uses 1-hour sleep cycles to avoid long blocking hibernation",
  "target_sensor_type": "generic",
  "actions": [
    {
      "type": "time_calc",
      "result_var": "CurrentTime",
      "time_op": "now",
      "output_unit": "seconds"
    },
    {
      "type": "log",
      "message": "🕐 Wake up! Current time: {CurrentTime}"
    },
    {
      "type": "if",
      "condition": {
        "left": "NextWeatherCheck",
        "operator": "==",
        "right": "0"
      },
      "then": [
        {
          "type": "variable_op",
          "name": "NextWeatherCheck",
          "operation": "=",
          "value": "CurrentTime",
          "var_type": "number"
        },
        {
          "type": "log",
          "message": "🆕 First run - initialized NextWeatherCheck"
        }
      ],
      "else": []
    },
    {
      "type": "if",
      "condition": {
        "left": "CurrentTime",
        "operator": ">=",
        "right": "NextWeatherCheck"
      },
      "then": [
        {
          "type": "log",
          "message": "⏰ Time to check weather!"
        },
        {
          "type": "variable_op",
          "name": "LastWeatherCheck",
          "operation": "=",
          "value": "CurrentTime",
          "var_type": "number"
        },
        {
          "type": "time_calc",
          "result_var": "NextWeatherCheck",
          "time_op": "add",
          "value_a": "CurrentTime",
          "value_b": "1800",
          "output_unit": "seconds",
          "value_b_unit": "minutes",
          "value_b_raw": "30"
        },
        {
          "type": "weather_fetch",
          "provider": "open-meteo",
          "api_key": "",
          "latitude": -34.08183,
          "longitude": 151.004129
        },
        {
          "type": "log",
          "message": "🌤️ Weather fetched! Sunrise: {sunrise}, Sunset: {sunset}"
        },
        {
          "type": "log",
          "message": "📅 Next weather check: {NextWeatherCheck}"
        }
      ],
      "else": [
        {
          "type": "log",
          "message": "⏳ Not yet time. Next check: {NextWeatherCheck}"
        }
      ]
    },
    {
      "type": "if",
      "condition": {
        "left": "sunset",
        "operator": "==",
        "right": "0"
      },
      "then": [
        {
          "type": "log",
          "message": "⚠️ No sunset data - sleeping 1 hour and retrying"
        },
        {
          "type": "hibernate",
          "duration": "1",
          "unit": "hours"
        }
      ],
      "else": [
        {
          "type": "if",
          "condition": {
            "left": "CurrentTime",
            "operator": ">=",
            "right": "sunset"
          },
          "then": [
            {
              "type": "log",
              "message": "🌙 Past sunset - sleeping in 1-hour cycles until sunrise"
            },
            {
              "type": "time_calc",
              "result_var": "TomorrowSunrise",
              "time_op": "add",
              "output_unit": "seconds",
              "value_a": "sunrise",
              "value_b": "86400",
              "value_b_unit": "days",
              "value_b_raw": "1"
            },
            {
              "type": "time_calc",
              "result_var": "HoursUntilSunrise",
              "time_op": "diff",
              "output_unit": "hours",
              "value_a": "TomorrowSunrise",
              "value_b": "CurrentTime"
            },
            {
              "type": "log",
              "message": "🌅 {HoursUntilSunrise} hours until sunrise - sleeping 1 hour"
            },
            {
              "type": "if",
              "condition": {
                "left": "HoursUntilSunrise",
                "operator": ">",
                "right": "0"
              },
              "then": [
                {
                  "type": "hibernate",
                  "duration": "1",
                  "unit": "hours"
                }
              ],
              "else": [
                {
                  "type": "log",
                  "message": "⚠️ Sunrise calculation error - sleeping 10 minutes"
                },
                {
                  "type": "hibernate",
                  "duration": "10",
                  "unit": "minutes"
                }
              ]
            }
          ],
          "else": [
            {
              "type": "time_calc",
              "result_var": "MinutesUntilSunset",
              "time_op": "diff",
              "output_unit": "minutes",
              "value_a": "sunset",
              "value_b": "CurrentTime"
            },
            {
              "type": "if",
              "condition": {
                "left": "MinutesUntilSunset",
                "operator": ">",
                "right": "60"
              },
              "then": [
                {
                  "type": "log",
                  "message": "☀️ Daytime - {MinutesUntilSunset} min until sunset. Sleeping 30 min."
                },
                {
                  "type": "hibernate",
                  "duration": "30",
                  "unit": "minutes"
                }
              ],
              "else": [
                {
                  "type": "log",
                  "message": "🌆 Sunset soon ({MinutesUntilSunset} min) - sleeping 10 minutes"
                },
                {
                  "type": "hibernate",
                  "duration": "10",
                  "unit": "minutes"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
