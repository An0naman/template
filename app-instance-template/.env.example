# App Instance Configuration

# ============================================================================
# REQUIRED SETTINGS
# ============================================================================

# Unique name for this app instance (used as container name)
# Examples: homebrews, projects, recipes, inventory
APP_NAME=myapp

# External port for accessing the web interface
# Each instance must use a different port
# Examples: 5001, 5002, 5003, etc.
PORT=5001

# Framework version to use
# Options: 
#   - latest (always get newest features, may have breaking changes)
#   - v1.0.0 (specific version, stable)
#   - v1 (latest v1.x.x release)
VERSION=latest

# Optional: local path to the framework template directory
# Used by ./update.sh to refresh compose defaults automatically
TEMPLATE_SOURCE_DIR=

# Data storage paths (optional — defaults to ./data and ./uploads beside this file)
# Override these to store app data on a NAS or external drive.
#
# CasaOS users:
#   1. Open CasaOS → Files app → Network Drives → connect to your NAS via SMB/NFS
#   2. CasaOS mounts it at /mnt/<ip>/<share> (e.g. /mnt/192.168.68.106/NAS)
#   3. Set the paths below:
#
# DATA_DIR=/mnt/192.168.68.106/NAS/docker-apps/myapp/data
# UPLOADS_DIR=/mnt/192.168.68.106/NAS/docker-apps/myapp/uploads
DATA_DIR=
UPLOADS_DIR=

# ============================================================================
# OPTIONAL SETTINGS
# ============================================================================

# Network range for ESP32 device auto-discovery
# Format: 192.168.x.0/24
# Only needed if you use IoT sensors
NETWORK_RANGE=192.168.1.0/24

# Primary AI provider (optional)
# Leave blank to configure via the UI instead
# Options: gemini, ollama
AI_PROVIDER=

# Google Gemini API key for AI features
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Optional Ollama settings
# Examples:
#   OLLAMA_BASE_URL=http://host.docker.internal:8080
#   OLLAMA_BASE_URL=https://your-machine.your-tailnet.ts.net
# Leave blank to configure via Settings → AI Configuration
OLLAMA_BASE_URL=
OLLAMA_MODEL_NAME=

# Push notification settings (ntfy.sh)
# Topic name for notifications (must be unique)
NTFY_TOPIC=

# Server URL (default: https://ntfy.sh)
NTFY_SERVER_URL=https://ntfy.sh

# Auth token for private topics (optional)
NTFY_AUTH_TOKEN=

# Flask secret key for session management
# IMPORTANT: Change this in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production

# Debug mode (set to true only for development)
DEBUG=false

# ============================================================================
# AUTOMATIC UPDATES (WATCHTOWER)
# ============================================================================

# How often to check for updates (in seconds)
# Default: 300 (5 minutes)
# Options: 60 (1 min), 300 (5 min), 3600 (1 hour), 86400 (daily)
WATCHTOWER_POLL_INTERVAL=300

# Notification service for update alerts (optional)
# Leave empty to disable notifications
# Options: shoutrrr (supports ntfy, email, Discord, Slack, etc.)
WATCHTOWER_NOTIFICATIONS=

# Notification URL (examples):
# - ntfy.sh: ntfy://ntfy.sh/your-updates-topic
# - Email: smtp://user:password@host:port/?from=sender@example.com&to=recipient@example.com
# - Discord: discord://token@webhookid
# - Slack: slack://token@channel
WATCHTOWER_NOTIFICATION_URL=

# Timezone for watchtower logs
TZ=UTC
