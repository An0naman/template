{
  "name": "Weather Check Script - Power Cycle Safe",
  "version": "1.0.18",
  "description": "Handles power cycles gracefully with short sleep cycles",
  "target_sensor_type": "generic",
  "actions": [
    {
      "type": "time_calc",
      "result_var": "CurrentTime",
      "time_op": "now",
      "output_unit": "seconds"
    },
    {
      "type": "log",
      "message": "🔌 Device started! Current time: {CurrentTime}"
    },
    {
      "type": "log",
      "message": "📊 Debug - NextWeatherCheck={NextWeatherCheck}"
    },
    {
      "type": "log",
      "message": "📊 Debug - sunset={sunset}, sunrise={sunrise}"
    },
    {
      "type": "if",
      "condition": {
        "left": "NextWeatherCheck",
        "operator": "==",
        "right": "0"
      },
      "then": [
        {
          "type": "variable_op",
          "name": "NextWeatherCheck",
          "operation": "=",
          "value": "CurrentTime",
          "var_type": "number"
        },
        {
          "type": "log",
          "message": "🆕 First run (or variables lost) - forcing weather check"
        }
      ],
      "else": [
        {
          "type": "log",
          "message": "✅ Variables restored from previous run"
        }
      ]
    },
    {
      "type": "if",
      "condition": {
        "left": "CurrentTime",
        "operator": ">=",
        "right": "NextWeatherCheck"
      },
      "then": [
        {
          "type": "log",
          "message": "⏰ Time to check weather!"
        },
        {
          "type": "variable_op",
          "name": "LastWeatherCheck",
          "operation": "=",
          "value": "CurrentTime",
          "var_type": "number"
        },
        {
          "type": "time_calc",
          "result_var": "NextWeatherCheck",
          "time_op": "add",
          "value_a": "CurrentTime",
          "value_b": "1800",
          "output_unit": "seconds",
          "value_b_unit": "minutes",
          "value_b_raw": "30"
        },
        {
          "type": "weather_fetch",
          "provider": "open-meteo",
          "api_key": "",
          "latitude": -34.08183,
          "longitude": 151.004129
        },
        {
          "type": "log",
          "message": "🌤️ Weather fetched! Sunrise: {sunrise}, Sunset: {sunset}"
        },
        {
          "type": "log",
          "message": "📅 Next weather check: {NextWeatherCheck}"
        }
      ],
      "else": [
        {
          "type": "log",
          "message": "⏳ Not yet time. Next check at: {NextWeatherCheck}"
        }
      ]
    },
    {
      "type": "if",
      "condition": {
        "left": "sunset",
        "operator": "==",
        "right": "0"
      },
      "then": [
        {
          "type": "log",
          "message": "⚠️ No sunset data - waiting 30 seconds then will retry"
        },
        {
          "type": "delay",
          "ms": "30000"
        }
      ],
      "else": [
        {
          "type": "log",
          "message": "✅ Have weather data - sunset={sunset}, sunrise={sunrise}"
        },
        {
          "type": "if",
          "condition": {
            "left": "CurrentTime",
            "operator": ">=",
            "right": "sunset"
          },
          "then": [
            {
              "type": "log",
              "message": "🌙 Past sunset - using short sleep cycles"
            },
            {
              "type": "time_calc",
              "result_var": "TomorrowSunrise",
              "time_op": "add",
              "output_unit": "seconds",
              "value_a": "sunrise",
              "value_b": "86400",
              "value_b_unit": "days",
              "value_b_raw": "1"
            },
            {
              "type": "log",
              "message": "🌅 Tomorrow sunrise will be: {TomorrowSunrise}"
            },
            {
              "type": "time_calc",
              "result_var": "HoursUntilSunrise",
              "time_op": "diff",
              "output_unit": "hours",
              "value_a": "TomorrowSunrise",
              "value_b": "CurrentTime"
            },
            {
              "type": "log",
              "message": "⏰ Hours until sunrise: {HoursUntilSunrise}"
            },
            {
              "type": "if",
              "condition": {
                "left": "HoursUntilSunrise",
                "operator": ">",
                "right": "2"
              },
              "then": [
                {
                  "type": "log",
                  "message": "💤 Sleeping 2 hours (can power cycle to wake early)"
                },
                {
                  "type": "hibernate",
                  "duration": "2",
                  "unit": "hours"
                }
              ],
              "else": [
                {
                  "type": "if",
                  "condition": {
                    "left": "HoursUntilSunrise",
                    "operator": ">",
                    "right": "0"
                  },
                  "then": [
                    {
                      "type": "log",
                      "message": "🌄 Sunrise soon - sleeping 30 minutes"
                    },
                    {
                      "type": "hibernate",
                      "duration": "30",
                      "unit": "minutes"
                    }
                  ],
                  "else": [
                    {
                      "type": "log",
                      "message": "☀️ Sunrise time! Staying awake."
                    },
                    {
                      "type": "delay",
                      "ms": "60000"
                    }
                  ]
                }
              ]
            }
          ],
          "else": [
            {
              "type": "time_calc",
              "result_var": "MinutesUntilSunset",
              "time_op": "diff",
              "output_unit": "minutes",
              "value_a": "sunset",
              "value_b": "CurrentTime"
            },
            {
              "type": "if",
              "condition": {
                "left": "MinutesUntilSunset",
                "operator": ">",
                "right": "60"
              },
              "then": [
                {
                  "type": "log",
                  "message": "☀️ Daytime - {MinutesUntilSunset} min until sunset. Sleeping 30 min."
                },
                {
                  "type": "hibernate",
                  "duration": "30",
                  "unit": "minutes"
                }
              ],
              "else": [
                {
                  "type": "log",
                  "message": "🌆 Sunset approaching ({MinutesUntilSunset} min) - waiting 10 min"
                },
                {
                  "type": "hibernate",
                  "duration": "10",
                  "unit": "minutes"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
