{
  "name": "Weather Check - Testing Mode",
  "version": "1.0.17",
  "description": "Uses delays instead of hibernation for easier testing",
  "target_sensor_type": "generic",
  "actions": [
    {
      "type": "time_calc",
      "result_var": "CurrentTime",
      "time_op": "now",
      "output_unit": "seconds"
    },
    {
      "type": "log",
      "message": "🕐 Current time: {CurrentTime}"
    },
    {
      "type": "if",
      "condition": {
        "left": "NextWeatherCheck",
        "operator": "==",
        "right": "0"
      },
      "then": [
        {
          "type": "variable_op",
          "name": "NextWeatherCheck",
          "operation": "=",
          "value": "CurrentTime",
          "var_type": "number"
        },
        {
          "type": "log",
          "message": "🆕 First run"
        }
      ],
      "else": []
    },
    {
      "type": "if",
      "condition": {
        "left": "CurrentTime",
        "operator": ">=",
        "right": "NextWeatherCheck"
      },
      "then": [
        {
          "type": "log",
          "message": "⏰ Checking weather..."
        },
        {
          "type": "time_calc",
          "result_var": "NextWeatherCheck",
          "time_op": "add",
          "value_a": "CurrentTime",
          "value_b": "120",
          "output_unit": "seconds",
          "value_b_unit": "minutes",
          "value_b_raw": "2"
        },
        {
          "type": "weather_fetch",
          "provider": "open-meteo",
          "api_key": "",
          "latitude": -34.08183,
          "longitude": 151.004129
        },
        {
          "type": "log",
          "message": "🌤️ Weather: Sunrise {sunrise}, Sunset {sunset}"
        }
      ],
      "else": [
        {
          "type": "log",
          "message": "⏳ Next check: {NextWeatherCheck}"
        }
      ]
    },
    {
      "type": "if",
      "condition": {
        "left": "sunset",
        "operator": ">",
        "right": "0"
      },
      "then": [
        {
          "type": "if",
          "condition": {
            "left": "CurrentTime",
            "operator": ">=",
            "right": "sunset"
          },
          "then": [
            {
              "type": "time_calc",
              "result_var": "TomorrowSunrise",
              "time_op": "add",
              "output_unit": "seconds",
              "value_a": "sunrise",
              "value_b": "86400",
              "value_b_unit": "days",
              "value_b_raw": "1"
            },
            {
              "type": "time_calc",
              "result_var": "HoursUntilSunrise",
              "time_op": "diff",
              "output_unit": "hours",
              "value_a": "TomorrowSunrise",
              "value_b": "CurrentTime"
            },
            {
              "type": "log",
              "message": "🌙 Nighttime - {HoursUntilSunrise} hours until sunrise"
            },
            {
              "type": "log",
              "message": "💤 [TEST MODE] Would hibernate, but using 30s delay instead"
            },
            {
              "type": "delay",
              "ms": "30000"
            }
          ],
          "else": [
            {
              "type": "time_calc",
              "result_var": "MinutesUntilSunset",
              "time_op": "diff",
              "output_unit": "minutes",
              "value_a": "sunset",
              "value_b": "CurrentTime"
            },
            {
              "type": "log",
              "message": "☀️ Daytime - {MinutesUntilSunset} minutes until sunset"
            },
            {
              "type": "log",
              "message": "⏸️ [TEST MODE] Waiting 30 seconds..."
            },
            {
              "type": "delay",
              "ms": "30000"
            }
          ]
        }
      ],
      "else": [
        {
          "type": "log",
          "message": "⏸️ No sunset data - waiting 30 seconds"
        },
        {
          "type": "delay",
          "ms": "30000"
        }
      ]
    }
  ]
}
